{
  "name": "superqtas-test-harness",
  "private": true,
  "type": "module",
  "scripts": {
    "test:qtas": "node tests/run-qtas-tests.mjs",
    "test:qtas:probe": "node tests/run-qtas-tests.mjs --probe",
    "test:qtas:list": "node tests/run-qtas-tests.mjs --list",
    "push:gas": "npx clasp push",
    "push:gas:prod": "npx clasp push",
    "push:gas:test": "npx clasp push --project .clasp.test.json",
    "pull:gas": "npx clasp pull",
    "pull:gas:prod": "npx clasp pull",
    "pull:gas:test": "npx clasp pull --project .clasp.test.json",
    "open:gas": "npx clasp open-script",
    "open:gas:prod": "npx clasp open-script",
    "open:gas:test": "npx clasp open-script --project .clasp.test.json"
  },
  "devDependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@google/clasp": "^3.0.4",
    "googleapis": "^144.0.0"
  }
}
