{
  "name": "superqtas-test-harness",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:qtas:bootstrap": "node tests/bootstrap-qtas-auth.mjs",
    "build:gas:prod": "node scripts/build-gas-bundle.mjs --target prod",
    "verify:gas:prod": "node scripts/verify-prod-surface.mjs",
    "test:qtas": "node tests/run-qtas-tests.mjs",
    "test:qtas:full": "npm run test:qtas",
    "test:qtas:probe": "node tests/run-qtas-tests.mjs --probe",
    "test:qtas:smoke": "node tests/run-qtas-tests.mjs --tag smoke",
    "test:qtas:qa": "node tests/run-qtas-tests.mjs --config tests/qtas.test.config.json",
    "test:qtas:full:qa": "npm run test:qtas:qa",
    "test:qtas:probe:qa": "node tests/run-qtas-tests.mjs --probe --config tests/qtas.test.config.json",
    "test:qtas:smoke:qa": "node tests/run-qtas-tests.mjs --config tests/qtas.test.config.json --tag smoke",
    "test:qtas:list": "node tests/run-qtas-tests.mjs --list",
    "deploy:test": "npm run push:gas:test && npm run test:qtas:probe:qa && npm run test:qtas:smoke:qa",
    "deploy:test:full": "npm run push:gas:test && npm run test:qtas:probe:qa && npm run test:qtas:qa",
    "deploy:test:push": "npm run push:gas:test",
    "deploy:prod": "npm run push:gas:prod",
    "deploy:prod:push": "npm run push:gas:prod",
    "deploy:safe": "npm run deploy:test && npm run deploy:prod",
    "push:gas": "npx clasp push -f",
    "push:gas:prod": "npm run build:gas:prod && npm run verify:gas:prod && npx clasp push -f --project .clasp.prod-build.json",
    "push:gas:test": "npx clasp push -f --project .clasp.test.json",
    "pull:gas": "npx clasp pull",
    "pull:gas:prod": "npx clasp pull",
    "pull:gas:test": "npx clasp pull --project .clasp.test.json",
    "open:gas": "npx clasp open-script",
    "open:gas:prod": "npx clasp open-script",
    "open:gas:test": "npx clasp open-script --project .clasp.test.json"
  },
  "devDependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@google/clasp": "^3.0.4",
    "googleapis": "^144.0.0"
  }
}
